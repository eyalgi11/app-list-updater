#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" >/dev/null 2>&1 && pwd -P)"
# shellcheck source=bin/lib/common
source "$SCRIPT_DIR/lib/common"

PROJECT_DIR="$(resolve_project_dir)"
current_step="startup"

usage() {
  printf 'Usage: %s [--dry-run]\n' "$0"
}

dry_run=0
case "${1:-}" in
  "")
    ;;
  --dry-run)
    dry_run=1
    ;;
  -h|--help)
    usage
    exit 0
    ;;
  *)
    usage >&2
    exit 2
    ;;
esac

run_step() {
  local label="$1"
  shift

  current_step="$label"
  printf '\n== %s ==\n' "$label"
  printf '+'
  printf ' %q' "$@"
  printf '\n'

  if (( ! dry_run )); then
    "$@"
  fi
}

notify_failure() {
  local exit_code="$?"
  "$PROJECT_DIR/bin/notify-maintenance" failure "Step failed: $current_step
Exit code: $exit_code" || true
  exit "$exit_code"
}

trap notify_failure ERR

run_step "Pre-upgrade AI inventory check" "$PROJECT_DIR/bin/update-app-list"
run_step "Supported unattended upgrades" "$PROJECT_DIR/bin/upgrade-apps"
run_step "Post-upgrade AI inventory re-check" "$PROJECT_DIR/bin/update-app-list"
run_step "Generate HTML dashboard" "$PROJECT_DIR/bin/generate-dashboard"

trap - ERR
if (( ! dry_run )); then
  "$PROJECT_DIR/bin/notify-maintenance" success || true
fi
