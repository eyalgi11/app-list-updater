#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" >/dev/null 2>&1 && pwd -P)"
# shellcheck source=bin/lib/common
source "$SCRIPT_DIR/lib/common"

PROJECT_DIR="$(resolve_project_dir)"
DASHBOARD_HOST="${APP_LIST_DASHBOARD_HOST:-127.0.0.1}"
DASHBOARD_PORT="${APP_LIST_DASHBOARD_PORT:-8765}"

"$PROJECT_DIR/bin/generate-dashboard" >/dev/null

printf 'Serving app maintenance dashboard at http://%s:%s/\n' "$DASHBOARD_HOST" "$DASHBOARD_PORT"
exec python3 -m http.server "$DASHBOARD_PORT" --bind "$DASHBOARD_HOST" --directory "$PROJECT_DIR"
