#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" >/dev/null 2>&1 && pwd -P)"
# shellcheck source=bin/lib/common
source "$SCRIPT_DIR/lib/common"

PROJECT_DIR="$(resolve_project_dir)"
APP_LIST_FILE="$PROJECT_DIR/apps.md"
LOG_DIR="$PROJECT_DIR/logs"

mkdir -p "$LOG_DIR"

status="${1:-success}"
detail="${2:-}"

usage() {
  printf 'Usage: %s [success|failure] [detail]\n' "$0"
}

case "$status" in
  success|failure)
    ;;
  -h|--help)
    usage
    exit 0
    ;;
  *)
    usage >&2
    exit 2
    ;;
esac

count_rows() {
  local mode="$1"
  awk -F '|' -v mode="$mode" '
    function trim(s) {
      gsub(/^[ \t]+|[ \t]+$/, "", s)
      gsub(/^`|`$/, "", s)
      return s
    }
    NR == 5 {
      for (i = 1; i <= NF; i++) {
        col[trim($i)] = i
      }
      next
    }
    NR > 6 {
      current = trim($(col["Current Version"]))
      repo = trim($(col["Repo Version"]))
      upstream = trim($(col["Upstream Version"]))
      auto = trim($(col["Auto Update"]))

      if (mode == "tracked") {
        count++
      } else if (mode == "installable" && repo != "" && repo != "n/a" && current != repo) {
        count++
      } else if (mode == "installable" && (repo == "n/a" || repo == "") && upstream != "" && current != upstream) {
        count++
      } else if (mode == "upstream" && upstream != "" && upstream != "n/a" && current != upstream && (repo == current || repo == "n/a")) {
        count++
      } else if (mode == "unsupported" && auto != "yes") {
        count++
      }
    }
    END {
      print count + 0
    }
  ' "$APP_LIST_FILE"
}

list_rows() {
  local mode="$1"
  local limit="${2:-5}"
  awk -F '|' -v mode="$mode" -v limit="$limit" '
    function trim(s) {
      gsub(/^[ \t]+|[ \t]+$/, "", s)
      gsub(/^`|`$/, "", s)
      return s
    }
    NR == 5 {
      for (i = 1; i <= NF; i++) {
        col[trim($i)] = i
      }
      next
    }
    NR > 6 {
      app = trim($2)
      current = trim($(col["Current Version"]))
      repo = trim($(col["Repo Version"]))
      upstream = trim($(col["Upstream Version"]))
      auto = trim($(col["Auto Update"]))
      method = trim($(col["Update Method"]))

      if (mode == "installable" && repo != "" && repo != "n/a" && current != repo) {
        item = app " (" current " -> " repo ")"
      } else if (mode == "installable" && (repo == "n/a" || repo == "") && upstream != "" && current != upstream) {
        item = app " (" current " -> " upstream ")"
      } else if (mode == "upstream" && upstream != "" && upstream != "n/a" && current != upstream && (repo == current || repo == "n/a")) {
        item = app
      } else if (mode == "unsupported" && auto != "yes") {
        item = app " (" method ")"
      } else {
        next
      }

      count++
      if (count <= limit) {
        if (out != "") out = out ", "
        out = out item
      }
    }
    END {
      if (count == 0) {
        print "none"
      } else if (count > limit) {
        print out ", +" (count - limit) " more"
      } else {
        print out
      }
    }
  ' "$APP_LIST_FILE"
}

tracked="$(count_rows tracked)"
installable="$(count_rows installable)"
upstream="$(count_rows upstream)"
unsupported="$(count_rows unsupported)"
installable_names="$(list_rows installable 4)"
upstream_names="$(list_rows upstream 4)"
unsupported_names="$(list_rows unsupported 4)"

if [[ "$status" == "success" ]]; then
  title="App maintenance finished"
  body="Tracked: $tracked
Installable updates: $installable
Newer upstream only: $upstream
Unsupported/manual: $unsupported
Installable: $installable_names
Manual: $unsupported_names
Upstream only: $upstream_names"
else
  title="App maintenance failed"
  body="${detail:-Check logs in $LOG_DIR}"
fi

printf '%s %s\n%s\n\n' "$(date --iso-8601=seconds)" "$title" "$body" >> "$LOG_DIR/notifications.log"

if [[ -z "${DISPLAY:-}" && -z "${WAYLAND_DISPLAY:-}" && -z "${DBUS_SESSION_BUS_ADDRESS:-}" ]]; then
  printf '%s\n%s\n' "$title" "$body"
elif command -v notify-send >/dev/null 2>&1; then
  notify-send "$title" "$body" || true
elif command -v kdialog >/dev/null 2>&1; then
  setsid -f kdialog --passivepopup "$title

$body" 12 >/dev/null 2>&1 || true
else
  printf '%s\n%s\n' "$title" "$body"
fi
